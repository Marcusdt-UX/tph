<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {% if canonical %}<link rel="canonical" href="{{ canonical }}">{% elif page.url %}<link rel="canonical" href="{{ site.url }}{{ page.url }}">{% endif %}
  {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  {% if ogUrl %}<meta property="og:url" content="{{ ogUrl }}">{% elif page.url %}<meta property="og:url" content="{{ site.url }}{{ page.url }}">{% endif %}
  <meta property="og:image" content="{{ ogImage or (site.url + '/assets/images/logo.png') }}">
  <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}">
  <meta name="twitter:title" content="{{ twitterTitle or ogTitle or title }}">
  <meta name="twitter:description" content="{{ twitterDescription or ogDescription or description }}">
  <meta name="twitter:image" content="{{ twitterImage or ogImage or (site.url + '/assets/images/logo.png') }}">
  <link rel="icon" type="image/png" href="/assets/images/logo.png">
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} Blog" href="/feed.xml">
  <link rel="stylesheet" href="/assets/css/styles.min.css">
  <script src="/assets/js/main.min.js"></script>
  <script src="/assets/js/lucide.min.js"></script>
  {% if schema %}
  <script type="application/ld+json">
  {{ schema | safe }}
  </script>
  {% endif %}
  {% if page.url != "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ site.url }}/"
      }{% if page.url | startsWith("/blog/") and page.url != "/blog.html" %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "{{ site.url }}/blog.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }{% elif page.url | startsWith("/areas/") %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "{{ site.url }}/services.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }{% elif page.url | startsWith("/portfolio/") and page.url != "/portfolio.html" %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Portfolio",
        "item": "{{ site.url }}/portfolio.html"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "{{ title }}"
      }{% else %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ title }}"
      }{% endif %}
    ]
  }
  </script>
  {% endif %}
  {% block extraHead %}{% endblock %}
</head>
<body>
  <noscript><div style="padding:2rem;text-align:center;font-family:sans-serif;background:#1a1a2e;color:#fff;">This site works best with JavaScript enabled. <a href="/contact.html" style="color:#00d9ff;">Contact us</a> directly if needed.</div></noscript>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="page-wrapper">
    <div class="texture-overlay"></div>
    <div class="custom-cursor-dot"></div>
    <div class="custom-cursor-ring"></div>

    <!-- Header -->
    <header class="header">
      <div class="header-bg"></div>
      <div class="container">
        <a href="/index.html" class="logo">
          <div class="logo-img">
            <img src="/assets/images/logo.png" alt="Thomas Publishing House logo">
          </div>
          <div class="logo-text">
            <h1>Thomas Publishing House</h1>
            <p>Digital Marketing</p>
          </div>
        </a>
        <nav class="desktop-nav">
          <a href="/index.html" class="nav-link">Home</a>
          <a href="/services.html" class="nav-link">Services</a>
          <a href="/portfolio.html" class="nav-link">Portfolio</a>
          <a href="/pricing.html" class="nav-link">Pricing</a>
          <a href="/about.html" class="nav-link">About</a>
          <a href="/faq.html" class="nav-link">FAQ</a>
          <button class="theme-toggle" aria-label="Toggle theme">
            <div class="theme-toggle-bg"></div>
            <div class="theme-toggle-inner"></div>
            <i data-lucide="moon" class="icon-moon"></i>
            <i data-lucide="sun" class="icon-sun"></i>
          </button>
          <a href="/contact.html" class="nav-cta">
            <div class="btn-gradient"></div>
            <div class="btn-inner"></div>
            <span>Contact Us</span>
          </a>
        </nav>
        <button class="mobile-menu-btn" aria-label="Toggle menu">
          <i data-lucide="menu" class="menu-icon-open"></i>
          <i data-lucide="x" class="menu-icon-close" style="display:none"></i>
        </button>
      </div>
      <nav class="mobile-nav">
          <a href="/index.html">Home</a>
          <a href="/services.html">Services</a>
          <a href="/portfolio.html">Portfolio</a>
          <a href="/pricing.html">Pricing</a>
          <a href="/about.html">About</a>
          <a href="/faq.html">FAQ</a>
          <div style="padding:0.5rem 1rem;">
            <button class="theme-toggle" aria-label="Toggle theme">
              <div class="theme-toggle-bg"></div>
              <div class="theme-toggle-inner"></div>
              <i data-lucide="moon" class="icon-moon"></i>
              <i data-lucide="sun" class="icon-sun"></i>
            </button>
          </div>
          <a href="/contact.html" class="mobile-nav-cta">Contact Us</a>
      </nav>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="main-content"{% if mainStyle %} style="{{ mainStyle }}"{% endif %}>
      {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="pattern-overlay"></div>
      <div class="container footer-inner">
        <div class="footer-grid">
          <div class="footer-brand">
            <div class="logo">
              <div class="logo-img">
                <img src="/assets/images/logo.png" alt="Thomas Publishing House logo">
              </div>
              <div class="logo-text">
                <h3>Thomas Publishing House</h3>
                <p>Digital Marketing</p>
              </div>
            </div>
            <p>Empowering online success with tailored digital solutions — from innovative design and development to strategic marketing that drives real results.</p>
          </div>
          <div class="footer-links">
            <h4>Quick Links</h4>
            <a href="/index.html">Home</a>
            <a href="/services.html">Services</a>
            <a href="/portfolio.html">Portfolio</a>
            <a href="/pricing.html">Pricing</a>
            <a href="/about.html">About</a>
            <a href="/faq.html">FAQ</a>
            <a href="/contact.html">Contact</a>
          </div>
          <div class="footer-links">
            <h4>Service Areas</h4>
            <a href="/areas/st-clair-county.html">St. Clair County</a>
            <a href="/areas/marysville.html">Marysville</a>
            <a href="/areas/fort-gratiot.html">Fort Gratiot</a>
            <a href="/areas/marine-city.html">Marine City</a>
            <a href="/areas/macomb-county.html">Macomb County</a>
            <a href="/areas/sterling-heights.html">Sterling Heights</a>
            <a href="/areas/shelby-township.html">Shelby Township</a>
            <a href="/areas/clinton-township.html">Clinton Township</a>
            <a href="/areas/rochester-hills.html">Rochester Hills</a>
            <a href="/areas/warren.html">Warren</a>
            <a href="/areas/troy.html">Troy</a>
            <a href="/areas/chesterfield-township.html">Chesterfield Twp</a>
            <a href="/areas/roseville.html">Roseville</a>
            <a href="/areas/st-clair.html">St. Clair</a>
            <a href="/areas/mount-clemens.html">Mt. Clemens</a>
            <a href="/areas/algonac.html">Algonac</a>
            <a href="/areas/east-china-township.html">East China Twp</a>
            <a href="/areas/royal-oak.html">Royal Oak</a>
            <a href="/areas/grosse-pointe.html">Grosse Pointe</a>
            <a href="/areas/sarnia.html">Sarnia, ON</a>
          </div>
          <div class="footer-contact">
            <h4>Contact</h4>
            <p>Port Huron, Michigan</p>
            <p>{{ site.email }}</p>
            <p>{{ site.phone }}</p>
            <div class="footer-social">
              <a href="{{ site.facebook }}" aria-label="Facebook" target="_blank" rel="noopener noreferrer"><i data-lucide="facebook"></i></a>
              <a href="{{ site.linkedin }}" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer"><i data-lucide="linkedin"></i></a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; <span id="current-year"></span> Thomas Publishing House. All rights reserved.</p>
          <a href="/privacy.html" style="color:var(--muted-foreground);font-size:0.8125rem;text-decoration:underline;text-underline-offset:2px;">Privacy Policy</a>
        </div>
      </div>
    </footer>
  </div>
</body>
</html>
